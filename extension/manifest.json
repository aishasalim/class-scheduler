{
  "manifest_version": 3,
  "name": "ZLP Schedule Importer (Aggie Schedule Builder)",
  "version": "0.1.0",
  "description": "Import a TAMU Aggie Schedule Builder class schedule into the ZLP Scheduler app.",
  "action": {
    "default_title": "Import my schedule",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://tamu.collegescheduler.com/*",
    "https://*.collegescheduler.com/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tamu.collegescheduler.com/*",
        "https://*.collegescheduler.com/*",
        "file:///*aggie-schedule-builder.html",
        "http://localhost:3000/mock/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
